# contracts/.env — Deployment-only secrets
# ════════════════════════════════════════════════════════════════════════════════
#
# SECURITY: This file is for CONTRACT DEPLOYMENT ONLY.
#   - Never commit this file (it is in .gitignore)
#   - The DEPLOYER_PRIVATE_KEY must NEVER appear in the Next.js/Vercel app environment
#   - Once mainnet deployment is complete, move this file offline (encrypted vault)
#   - The relayer key (NEXT.js env) and the deployer key (here) MUST be different wallets
#
# Usage:
#   cp .env.example .env
#   # Fill in your values
#   cd contracts
#   forge script script/Deploy.s.sol --rpc-url qie_testnet            # dry run
#   forge script script/Deploy.s.sol --rpc-url qie_mainnet --broadcast --verify

# ── Deployer key (HIGH VALUE — keep offline after deploy) ─────────────────────
# This wallet must have enough native QIE for deployment gas.
# After deployment, do NOT fund this wallet further or use it for anything else.
DEPLOYER_PRIVATE_KEY=<YOUR_DEPLOYER_PRIVATE_KEY>

# ── QIE Mainnet RPC ───────────────────────────────────────────────────────────
QIE_MAINNET_RPC=https://rpc1mainnet.qie.digital/

# ── Blockscout verification (any non-empty string works for Blockscout) ────────
QIE_EXPLORER_KEY=placeholder

# ── Contract constructor args ─────────────────────────────────────────────────

# QUSD/QUSDC stablecoin address on QIE mainnet (official, 6 decimals, $1 rate)
QUSD_ADDRESS=0x3F43DA82eC9A4f5285F10FaF1F26EcA7319E5DA5

# Multisig — becomes TimelockController proposer/executor
# For hackathon: use deployer address; for production: use a Gnosis Safe
MULTISIG_ADDRESS=<YOUR_DEPLOYER_OR_GNOSIS_SAFE_ADDRESS>

# QIE Pass oracle — trusted signer for KYC verification
# For hackathon: use deployer address; for production: use official QIE Pass oracle
PASS_ORACLE_ADDRESS=<YOUR_DEPLOYER_ADDRESS>

# Fee treasury — receives 0.1% protocol fee
FEE_TREASURY_ADDRESS=<YOUR_FEE_TREASURY_ADDRESS>
